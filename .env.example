# Meluvis CRM — environment (copy to `.env` or `.env.local`, do not commit secrets)
# Docs: docs/TECH_CARD.md, Documents/Done Tasks/ENVIRONMENT.md

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Optional: direct connection for migrations (Neon)
# DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# ——— NextAuth.js ———
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ——— External API (Bearer) ———
API_TOKEN="your-api-token-for-external-systems"

# ——— Cloudflare R2 ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ——— Rate limiting (optional, recommended for production) ———
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# ——— Optional ———
# LOG_LEVEL="info"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# VERIFY_API_BASE_URL="http://localhost:3000"
