{
  "name": "meluviscrm",
  "version": "1.0.0",
  "description": "Real Estate CRM система для управления комплексом недвижимости",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "verify": "vitest run && next build",
    "vercel-build": "prisma generate && (prisma migrate deploy || true) && next build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/create-users.ts",
    "db:seed-data": "tsx scripts/seed-data.ts",
    "db:generate-test": "tsx scripts/generate-test-data.ts",
    "db:import-csv": "tsx scripts/import-from-csv.ts",
    "db:import-excel": "tsx scripts/import-from-excel.ts",
    "db:export-sales": "tsx scripts/export-sales-3days.ts",
    "db:seed-attachments-r2": "tsx scripts/seed-attachments-from-r2.ts",
    "verify-api": "tsx scripts/verify-external-api.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@prisma/client": "^5.20.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.562.0",
    "next": "^16.1.7",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.19",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.39",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neetrino-com/meluviscrm.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
